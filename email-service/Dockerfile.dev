# Dev uses a single stage for speed + hot‑reload tools
FROM node:23-alpine

# Install git, bash, and optional debuggers
RUN apk add --no-cache git bash tini

WORKDIR /usr/src/app

# Copy manifests and install *all* deps (including devDeps)
COPY package*.json tsconfig*.json ./
RUN npm install

# Copy the rest of the code
COPY . .

# Mount local source by default in docker‑compose so host edits sync
ENV NODE_ENV=development
EXPOSE 5002

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["npm", "run", "dev"]
