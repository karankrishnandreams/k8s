{
  "name": "application-service",
  "version": "1.0.0",
  "main": ".eslintrc.js",
  "scripts": {
    "start": "node dist/bootstrap.js",
    "dev": "ts-node-dev --respawn --transpile-only src/bootstrap.ts",
    "local": "ts-node-dev --respawn --transpile-only src/bootstrap.ts --env=localrun",
    "build": "rimraf dist && tsc",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "supadminseed": "ts-node -r tsconfig-paths/register src/utils/superadmin.ts",
    "supadminseed:local": "npm run supadminseed -- --env=localrun",
    "supadminseed:qa": "npm run supadminseed -- --env=qa",
    "supadminseed:prod": "npm run supadminseed -- --env=production"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.828.0",
    "@aws-sdk/lib-storage": "^3.828.0",
    "@aws-sdk/s3-request-presigner": "^3.828.0",
    "axios-retry": "^4.5.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.1.0",
    "html-entities": "^2.6.0",
    "http-errors": "^2.0.0",
    "jsonwebtoken": "^9.0.2",
    "module-alias": "^2.2.3",
    "moment": "^2.30.1",
    "mongoose": "^8.13.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.17.1",
    "slugify": "^1.6.6",
    "ts-node-dev": "^2.0.0",
    "twilio": "^5.6.0",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.1",
    "@types/helmet": "^0.0.48",
    "@types/http-errors": "^2.0.4",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/module-alias": "^2.0.4",
    "@types/mongoose": "^5.11.96",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.14.1",
    "@types/pdfkit": "^0.14.0",
    "@types/winston": "^2.4.4",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3"
  },
  "_moduleAliases": {
    "@config": "dist/config",
    "@controllers": "dist/controllers",
    "@interfaces": "dist/interfaces",
    "@middlewares": "dist/middlewares",
    "@models": "dist/models",
    "@routes": "dist/routes",
    "@services": "dist/services",
    "@utils": "dist/utils"
  }
}